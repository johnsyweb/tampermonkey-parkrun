{
  "name": "tampermonkey-parkrun",
  "version": "1.0.0",
  "description": "A script or scripts for messing with parkrun results pages",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "build:data": "npm run docs:assets",
    "update-version": "node scripts/update-version.js",
    "screenshots": "ts-node scripts/generate-screenshots.ts",
    "update-scripts-data": "node scripts/extract-script-info.js",
    "docs:assets": "npm run build:scripts && npm run screenshots && node scripts/generate-thumbnails.js && npm run update-scripts-data",
    "docs:build": "npm run docs:assets && cd docs && bundle exec jekyll build && node ../scripts/generate-sitemap.js",
    "docs:check": "cd docs && bundle exec htmlproofer ./_site --disable-external --root-dir \"$(pwd)/_site\" --swap-urls 'tampermonkey-parkrun/:' || echo \"htmlproofer reported issues (non-fatal)\"",
    "docs:install": "cd docs && bundle install",
    "docs:serve": "npm run docs:assets && cd docs && bundle exec jekyll serve",
    "build:scripts": "node scripts/build-scripts.js",
    "preview": "npm run build:scripts && node scripts/preview-userscript.js",
    "check:userscripts": "node scripts/check-userscript-metadata.js *.user.js",
    "ci": "npm run build:scripts && npm run check:userscripts && npm test && npm run lint && npm run docs:build && npm run docs:check",
    "prepare": "husky"
  },
  "keywords": [
    "parkrun",
    "tampermonkey",
    "bookmarklet",
    "user script"
  ],
  "author": "Pete Johns (@johnsyweb)",
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "minimatch": "10.2.2",
      "jest-environment-jsdom": "30.4.1",
      "jest-mock": "30.4.1"
    },
    "allowBuilds": {
      "esbuild": true,
      "puppeteer": true,
      "sharp": true,
      "unrs-resolver": true
    }
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "babel-jest": "^30.4.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.1",
    "jest-environment-jsdom": "^30.4.1",
    "jest-fixed-jsdom": "^0.0.11",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "puppeteer": "^25.1.0",
    "sharp": "^0.35.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "uglify-js": "^3.19.3"
  },
  "jest": {
    "testEnvironment": "jest-fixed-jsdom",
    "transformIgnorePatterns": [
      "node_modules/(?!(.pnpm|.aube|parse5|whatwg-url|tr46|webidl-conversions|jsdom|@exodus|html-encoding-sniffer)/)"
    ],
    "transform": {
      "^.+\\.(js|mjs)$": "babel-jest"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "endOfLine": "lf"
  }
}
